{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate config for leadershipmosaics repos. Encodes ADR-0005 two-tier dependency currency model.",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard"
  ],
  "schedule": ["before 9am on monday"],
  "timezone": "Europe/Amsterdam",
  "labels": ["dependencies"],
  "prHourlyLimit": 3,
  "prConcurrentLimit": 5,
  "postUpdateOptions": ["npmInstallTwice"],
  "packageRules": [
    {
      "description": "Tier 1: Auto-merge patch updates (post-1.0 packages)",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Tier 1: Group all non-major npm updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "npm non-major updates"
    },
    {
      "description": "Tier 1: Group GitHub Actions minor/patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "GitHub Actions updates",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Tier 2: Major updates require manual review (governed decision per ADR-0005)",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "major-version"]
    }
  ]
}
